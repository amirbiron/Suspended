# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_CHAT_ID=your_admin_chat_id_here

# Render API Configuration
RENDER_API_KEY=your_render_api_key_here

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/
# או עבור MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# GitHub (optional) - for creating Gists from the bot
# Create a Personal Access Token with `gist` scope
GITHUB_GIST_TOKEN=your_github_pat_with_gist_scope_here

# Telegram (optional) - custom emoji id for the Gist button (Bot API 9.4+)
GIST_BUTTON_CUSTOM_EMOJI_ID=5368324170671202305

# הערות להגדרה:
# 1. צור בוט טלגרם חדש ב-@BotFather וקבל את ה-TOKEN
# 2. קבל את ה-CHAT_ID שלך על ידי שליחת הודעה לבוט ובדיקה בכתובת:
#    https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# 3. קבל את ה-RENDER_API_KEY מהפרופיל שלך ב-Render
# 4. הגדר חיבור MongoDB (מקומי או Atlas)
